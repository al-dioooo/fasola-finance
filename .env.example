# Copy to .env and fill in the blanks.

NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Shared local PostgreSQL (same database as fasola-order-bot).
DATABASE_URL=postgres://postgres@localhost:5432/fasola

# Auth — single admin login for the dashboard.
# ADMIN_PASSWORD: at least 12 characters.
# SESSION_SECRET: generate with `openssl rand -hex 32`.
ADMIN_PASSWORD=
SESSION_SECRET=
SESSION_TTL_DAYS=30

# GoWA (go-whatsapp-web-multidevice) REST API — same credentials the bot uses.
GOWA_BASE_URL=http://127.0.0.1:3001
GOWA_BASIC_AUTH_USER=
GOWA_BASIC_AUTH_PASSWORD=

# fasola-order-bot health endpoint.
BOT_BASE_URL=http://127.0.0.1:3010
