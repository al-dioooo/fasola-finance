# Copy to .env and fill in the blanks.

NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Shared local PostgreSQL (same database as fasola-order-bot).
DATABASE_URL=postgres://postgres@localhost:5432/fasola

# Auth — single admin login for the dashboard.
# ADMIN_PASSWORD: at least 12 characters.
# SESSION_SECRET: generate with `openssl rand -hex 32`.
ADMIN_PASSWORD=
SESSION_SECRET=
SESSION_TTL_DAYS=30

# GoWA (go-whatsapp-web-multidevice) REST API — same credentials the bot uses.
GOWA_BASE_URL=http://127.0.0.1:3001
GOWA_BASIC_AUTH_USER=
GOWA_BASIC_AUTH_PASSWORD=

# fasola-order-bot health endpoint + internal API (GoFood control).
BOT_BASE_URL=http://127.0.0.1:3010
# Bearer token for the bot's /internal/gofood/* endpoints. Must match the bot's
# INTERNAL_API_TOKEN. Leave blank until GoFood is set up.
BOT_INTERNAL_TOKEN=

# Product images for the GoFood catalog are uploaded here and served at
# PUBLIC_BASE_URL/uploads/<file>. In production PUBLIC_BASE_URL must be the
# dashboard's public https origin so GoFood can fetch the images.
PUBLIC_BASE_URL=http://localhost:3100
UPLOADS_DIR=./data/uploads
