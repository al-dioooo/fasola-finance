{
  "name": "fasola-finance",
  "version": "1.0.0",
  "private": true,
  "description": "Admin dashboard for Dapoer Mami Fasola: orders, sales reports, menu, expenses & profit, and WhatsApp bot operations. Shares the local PostgreSQL database with fasola-order-bot.",
  "main": "dist/server/server.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/server/server.js",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:reset:seed": "npm run db:reset && npm run db:seed",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit && tsc -p tsconfig.eslint.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.0.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "motion": "^12.42.2",
    "nanoid": "^5.1.11",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/react-query": "^5.90.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.0",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.0",
    "recharts": "^3.3.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.2.0",
    "vitest": "^4.1.8"
  }
}
